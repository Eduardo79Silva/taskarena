#!/bin/bash

set -euo pipefail

tag=$(walker --dmenu -p "Tag (optional):") || true
time=$(walker --dmenu -p "Time (optional):") || true

args=()

[[ -n "$tag" ]] && args+=(--tag "$tag")
[[ -n "$time" ]] && args+=(--time "$time")

taskarena pull "${args[@]}"

output=$(taskarena status --format notify)
task_line=$(echo "$output" | tail -n 1)

notify-send -a "Tasks" "Next task" "$task_line"
